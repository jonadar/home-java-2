<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>


<AnchorPane prefHeight="286.0" prefWidth="250.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/26" fx:controller="controllers.updetUserInfoPage">
   <children>
      <VBox layoutX="44.0" layoutY="80.0" prefHeight="117.0" prefWidth="161.0">
         <children>
            <Button mnemonicParsing="false" onAction="#email" prefWidth="200.0" style="-fx-background-color: #74fbdb; -fx-border-color: #74b5fb;" text="email">
               <VBox.margin>
                  <Insets top="5.0" />
               </VBox.margin>
            </Button>
            <Button mnemonicParsing="false" onAction="#phonNum" prefWidth="200.0" style="-fx-background-color: #74fbdb; -fx-border-color: #74b5fb;" text="phon number">
               <VBox.margin>
                  <Insets top="5.0" />
               </VBox.margin>
            </Button>
            <Button mnemonicParsing="false" onAction="#adress" prefWidth="200.0" style="-fx-background-color: #74fbdb; -fx-border-color: #74b5fb;" text="adress">
               <VBox.margin>
                  <Insets top="5.0" />
               </VBox.margin>
            </Button>
            <TextField fx:id="text" prefWidth="200.0">
               <VBox.margin>
                  <Insets top="5.0" />
               </VBox.margin>
            </TextField>
         </children>
      </VBox>
      <Label layoutX="41.0" layoutY="21.0" text="update personal info">
         <font>
            <Font name="Berlin Sans FB Demi Bold" size="18.0" />
         </font>
      </Label>
      <Button layoutX="180.0" layoutY="241.0" mnemonicParsing="false" onAction="#exit" style="-fx-background-color: red;" text="exit">
         <font>
            <Font name="System Bold" size="14.0" />
         </font>
      </Button>
   </children>
</AnchorPane>
