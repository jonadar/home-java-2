      </VBox>
      <VBox layoutX="487.0" layoutY="253.0" prefHeight="53.0" prefWidth="199.0">
         <children>
            <Button mnemonicParsing="false" onAction="#searchRestaurantManager" prefWidth="200.0" text="Search Restaurant Manager" textAlignment="CENTER" />
            <TextField fx:id="text3" />
         </children>
      </VBox>
   </children>
</AnchorPane>
