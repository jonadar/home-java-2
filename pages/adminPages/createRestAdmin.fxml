<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>


<AnchorPane prefHeight="306.0" prefWidth="255.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/26" fx:controller="controllers.createRestAdminController">
   <children>
      <VBox layoutX="25.0" layoutY="37.0" prefHeight="200.0" prefWidth="210.0">
         <children>
            <Label text="name" />
            <TextField fx:id="nameInput">
               <VBox.margin>
                  <Insets bottom="10.0" />
               </VBox.margin>
            </TextField>
            <Label text="username" />
            <TextField fx:id="usernameInput">
               <VBox.margin>
                  <Insets bottom="10.0" />
               </VBox.margin>
            </TextField>
            <Label text="password" />
            <TextField fx:id="passwordInput">
               <VBox.margin>
                  <Insets bottom="10.0" />
               </VBox.margin>
            </TextField>
            <Button mnemonicParsing="false" onAction="#createAdmin" prefHeight="25.0" prefWidth="266.0" text="create restaurant admin" />
         </children>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
      </VBox>
      <Button layoutX="176.0" layoutY="238.0" mnemonicParsing="false" onAction="#exit" text="go back" />
      <Label layoutX="35.0" layoutY="14.0" text="create new rest admin">
         <font>
            <Font size="19.0" />
         </font>
      </Label>
   </children>
</AnchorPane>
